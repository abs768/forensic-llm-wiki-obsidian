# Forensic LLM Wiki — environment variables
#
# All variables are OPTIONAL. The default mock LLM mode requires nothing.
# Copy this file to .env and uncomment what you need.

# --- LLM provider selection ---
# "mock" (default) uses the deterministic rule-based extractor pipeline.
# Tests, demo, and benchmark all run in mock mode.
# "live" calls the Anthropic API and requires the `anthropic` package
# (install with `pip install -e ".[dev,live]"`) plus ANTHROPIC_API_KEY below.
# FORENSIC_WIKI_LLM=mock

# --- Live-mode model override (only when FORENSIC_WIKI_LLM=live) ---
# Default is claude-opus-4-7 if unset. Any current Claude model id works.
# FORENSIC_WIKI_MODEL=claude-opus-4-7

# --- Anthropic credentials (only when FORENSIC_WIKI_LLM=live) ---
# Get a key at https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...
