      "must_not_include": ["confirmed malware"]
    },
    {
      "id": "rel_002",
      "category": "relationship_retrieval",
      "question": "What relationships does the registry Run key have?",
      "expected_best_method": "graph_rag_lite",
      "must_include": ["DeskRest"],
      "must_not_include": ["confirmed malware"]
    },
    {
      "id": "rel_003",
      "category": "relationship_retrieval",
      "question": "What is 203.0.113.77 related to?",
      "expected_best_method": "graph_rag_lite",
      "must_include": ["DeskRest"],
      "must_not_include": ["confirmed malware"]
    },

    {
      "id": "multihop_001",
      "category": "multi_hop_relation",
      "question": "What links DeskRest.exe to outbound network activity?",
      "expected_best_method": "hybrid",
      "must_include": ["203.0.113.77"],
      "must_not_include": ["confirmed malware"]
    },
    {
      "id": "multihop_002",
      "category": "multi_hop_relation",
      "question": "What is connected to the registry Run key through DeskRest.exe?",
