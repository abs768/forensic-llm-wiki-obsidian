  "items": [
    {
      "id": "lookup_001",
      "category": "simple_lookup",
      "question": "Did the Windows Defender scan find any threats?",
      "expected_best_method": "llm_wiki",
      "must_include": ["Defender"],
      "must_not_include": ["confirmed malware"],
      "required_sources": ["defender_scan"]
    },
    {
      "id": "lookup_002",
      "category": "simple_lookup",
      "question": "What does the hash reputation lookup say about DeskRest.exe?",
      "expected_best_method": "llm_wiki",
      "must_include": ["hash"],
      "must_not_include": ["confirmed malicious"],
      "required_sources": ["hash_reputation"]
    },
    {
      "id": "lookup_003",
      "category": "simple_lookup",
      "question": "Are there any outbound network connections?",
      "expected_best_method": "llm_wiki",
      "must_include": ["203.0.113.77"],
      "must_not_include": ["no outbound"],
      "required_sources": ["network_connections.csv"]
    },

    {
      "id": "rel_001",
      "category": "relationship_retrieval",
      "question": "What is DeskRest.exe related to?",
      "expected_best_method": "graph_rag_lite",
